{
    "compilerOptions": {
        "target": "ES2020",
        "module": "commonjs",
        "lib": [
            "ES2020",
            "DOM"
        ],
        "types": ["vitest/globals"],
        "sourceMap": true,
        "moduleResolution": "Node",
        "outDir": "./dist",
        "declaration": true,
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "removeComments": true,
        "strict": true,
        "noImplicitAny": false,
        "skipLibCheck": true
    }
}